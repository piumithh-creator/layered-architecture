<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600" prefWidth="900"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.foundation_360.controller.EmployeeController">

    <children>
        <StackPane AnchorPane.topAnchor="0.0"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0">
            <children>
                <VBox alignment="TOP_CENTER" spacing="24.0">
                    <children>
                        <!-- Header -->
                        <VBox alignment="CENTER" spacing="4.0">
                            <children>
                                <Label text="Employee Management" styleClass="heading-title" textFill="#e5e7eb">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="Manage your employee records" styleClass="heading-subtitle" textFill="#9ca3af">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Card -->
                        <VBox alignment="TOP_CENTER" spacing="18.0" maxWidth="820.0" styleClass="card">
                            <children>
                                <!-- Form -->
                                <GridPane hgap="16.0" vgap="12.0">
                                    <children>
                                        <Label text="User ID" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtUserId" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                                        <Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtName" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="Role" GridPane.rowIndex="0" GridPane.columnIndex="2">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <ComboBox fx:id="comboRole" GridPane.rowIndex="1" GridPane.columnIndex="2" prefWidth="160"/>

                                        <Label text="Status" GridPane.rowIndex="0" GridPane.columnIndex="3">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtStatus" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                                        <Label text="Username" GridPane.rowIndex="2" GridPane.columnIndex="0">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtUsername" GridPane.rowIndex="3" GridPane.columnIndex="0"/>

                                        <Label text="Password" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtPassword" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                        <Label text="Salary" GridPane.rowIndex="2" GridPane.columnIndex="2">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtSalary" GridPane.rowIndex="3" GridPane.columnIndex="2"/>

                                        <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="3">
                                            <font><Font size="13.0"/></font>
                                        </Label>
                                        <TextField fx:id="txtEmail" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                                    </children>
                                </GridPane>

                                <!-- Buttons -->
                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnBack" text="Back" onAction="#handleBack" styleClass="nav-button" />
                                        <Button fx:id="btnAdd" text="Add Employee" onAction="#handleAdd" styleClass="add-button" />
                                        <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdate" styleClass="update-button" />
                                        <Button fx:id="btnDelete" text="Deactivate" onAction="#handleDelete" styleClass="delete-button" />
                                        <Button fx:id="btnSearch" text="Search" onAction="#handleSearch" styleClass="view-button" />
                                        <Button fx:id="btnSalary" text="Salary View" onAction="#handleSalaryView" styleClass="view-button" />
                                    </children>
                                </HBox>

                                <!-- TableView -->
                                <TableView fx:id="tableEmployees" prefHeight="260.0">
                                    <columns>
                                        <TableColumn fx:id="colEmployeeId" prefWidth="150" text="Employee ID" />
                                        <TableColumn fx:id="colName" prefWidth="200" text="Name" />
                                        <TableColumn fx:id="colRole" prefWidth="150" text="Role" />
                                        <TableColumn fx:id="colStatus" prefWidth="300" text="Status" />
                                    </columns>
                                </TableView>
                            </children>
                            <padding>
                                <Insets top="20" right="24" bottom="24" left="24"/>
                            </padding>
                        </VBox>
                    </children>
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>
