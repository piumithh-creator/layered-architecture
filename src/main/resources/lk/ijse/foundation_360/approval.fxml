<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foundation_360.controller.ApprovalController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>
         <children>
            <VBox spacing="4.0">
               <children>
                  <Label styleClass="heading-title" text="Approval Management">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label styleClass="heading-subtitle" text="Manage pending approvals and requests" />
               </children>
            </VBox>
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="tblApprovals" prefHeight="200.0" prefWidth="200.0" styleClass="table-view" HBox.hgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colReferenceType" prefWidth="120.0" text="Reference Type" />
                      <TableColumn fx:id="colReferenceId" prefWidth="100.0" text="Reference ID" />
                        <TableColumn fx:id="colRequestedBy" prefWidth="150.0" text="Requested By" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                        <TableColumn fx:id="colRequestDate" prefWidth="120.0" text="Request Date" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <VBox prefWidth="300.0" spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Action" />
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Remarks" />
                              <TextArea fx:id="txtRemarks" prefHeight="200.0" prefWidth="200.0" promptText="Enter remarks or rejection reason..." wrapText="true" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>
                        <HBox spacing="10.0">
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnRejectOnAction" styleClass="danger-button" text="Reject" HBox.hgrow="ALWAYS" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnApproveOnAction" styleClass="success-button" text="Approve" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
