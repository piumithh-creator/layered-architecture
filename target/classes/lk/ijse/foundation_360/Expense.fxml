<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="650.0" prefWidth="900.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foundation_360.controller.ExpenseController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>
         <children>
            <VBox spacing="4.0">
               <children>
                  <Label styleClass="heading-title" text="Expense Management">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label styleClass="heading-subtitle" text="Add and manage project expenses" />
               </children>
            </VBox>
            <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <HBox spacing="20.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Project ID" />
                              <ComboBox fx:id="cmbProjectId" maxWidth="1.7976931348623157E308" prefWidth="150.0" promptText="Select Project" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Category ID" />
                              <ComboBox fx:id="cmbCategoryId" maxWidth="1.7976931348623157E308" prefWidth="150.0" promptText="Select Category" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Amount" />
                              <TextField fx:id="txtAmount" promptText="0.00" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox spacing="20.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Reason / Description" />
                              <TextField fx:id="txtReason" promptText="Enter reason for expense" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Expense Date" />
                              <DatePicker fx:id="dpExpenseDate" maxWidth="1.7976931348623157E308" promptText="Select Date" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#btnClearOnAction" styleClass="secondary-button" text="Clear" />
                        <Button mnemonicParsing="false" onAction="#btnAddExpenseOnAction" styleClass="add-btn" text="Add Expense" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <TableView fx:id="tblExpenses" prefHeight="200.0" prefWidth="200.0" styleClass="table-view" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colExpenseId" prefWidth="75.0" text="Expense ID" />
                <TableColumn fx:id="colProjectId" prefWidth="100.0" text="Project ID" />
                  <TableColumn fx:id="colCategoryId" prefWidth="100.0" text="Category ID" />
                  <TableColumn fx:id="colAmount" prefWidth="100.0" text="Amount" />
                  <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                  <TableColumn fx:id="colRequestDate" prefWidth="120.0" text="Request Date" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
