<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.foundation_360.controller.SalaryViewController"
            prefWidth="1000" prefHeight="650"
>

    <!-- Title -->
    <Label text="Salary Management"
           layoutX="30" layoutY="20"
 />

    <!-- Form -->
    <VBox spacing="10" layoutX="30" layoutY="70"
          prefWidth="350"
>

        <Label text="Salary Details"
 />

        <TextField fx:id="txtSalaryId" promptText="Salary ID" />
        <TextField fx:id="txtEmployeeId" promptText="Employee ID" />
        <TextField fx:id="txtEmployeeName" promptText="Employee Name" />
        <TextField fx:id="txtBasicSalary" promptText="Basic Salary" />
        <TextField fx:id="txtAllowance" promptText="Allowance" />
        <TextField fx:id="txtDeduction" promptText="Deduction" />

        <HBox spacing="10">
            <Button text="Add"
                    onAction="#addSalary"

                    prefWidth="100"/>

            <Button text="Update"
                    onAction="#updateSalary"

                    prefWidth="100"/>

            <Button text="Delete"
                    onAction="#deleteSalary"

                    prefWidth="100"/>
        </HBox>

        <Button text="Clear"
                onAction="#clearFields"

                prefWidth="320"/>
    </VBox>

    <!-- Table -->
    <TableView fx:id="tblSalary"
               layoutX="410" layoutY="70"
               prefWidth="560" prefHeight="520"
>

        <columns>
            <TableColumn fx:id="colSalaryId" text="Salary ID" prefWidth="90"/>
            <TableColumn fx:id="colEmpId" text="Emp ID" prefWidth="80"/>
            <TableColumn fx:id="colEmpName" text="Name" prefWidth="120"/>
            <TableColumn fx:id="colBasic" text="Basic" prefWidth="80"/>
            <TableColumn fx:id="colAllowance" text="Allowance" prefWidth="80"/>
            <TableColumn fx:id="colDeduction" text="Deduction" prefWidth="80"/>
            <TableColumn fx:id="colNetSalary" text="Net Salary" prefWidth="90"/>
        </columns>

    </TableView>

</AnchorPane>
