<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foundation_360.controller.PreviousProjectsController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>
         <children>
            <VBox spacing="4.0">
               <children>
                  <Label styleClass="heading-title" text="Previous Projects">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label styleClass="heading-subtitle" text="View details of completed projects" />
               </children>
            </VBox>
            <TableView fx:id="tblPreviousProjects" prefHeight="200.0" prefWidth="200.0" styleClass="table-view" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colProjectId" prefWidth="75.0" text="Project ID" />
                <TableColumn fx:id="colProjectName" prefWidth="150.0" text="Project Name" />
                  <TableColumn fx:id="colClientId" prefWidth="100.0" text="Client ID" />
                  <TableColumn fx:id="colStartDate" prefWidth="100.0" text="Start Date" />
                  <TableColumn fx:id="colEndDate" prefWidth="100.0" text="End Date" />
                  <TableColumn fx:id="colEstimatedCost" prefWidth="120.0" text="Estimated Cost" />
                  <TableColumn fx:id="colActualCost" prefWidth="120.0" text="Actual Cost" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
