<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foundation_360.controller.ClientController">
   <children>
      <VBox spacing="20.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
         <children>
            <Label text="Client Management" styleClass="heading-title">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>

            <!-- Input fields -->
            <HBox spacing="20.0">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Client ID" styleClass="label">
                           <font><Font size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtClientId" prefHeight="40.0" />

                        <Label text="Name" styleClass="label">
                           <font><Font size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtClientName" prefHeight="40.0" />

                        <Label text="Contact" styleClass="label">
                           <font><Font size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtContact" prefHeight="40.0" />

                        <Label text="Email" styleClass="label">
                           <font><Font size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtEmail" prefHeight="40.0" />
                     </children>
                  </VBox>

                  <!-- Buttons -->
                  <VBox spacing="10.0" alignment="TOP_RIGHT">
                     <children>
                        <Button onAction="#add" prefHeight="40.0" prefWidth="150.0" text="Add Client" styleClass="add-button">
                           <font><Font size="14.0" /></font>
                        </Button>
                        <Button onAction="#update" prefHeight="40.0" prefWidth="150.0" text="Update" styleClass="update-button">
                           <font><Font size="14.0" /></font>
                        </Button>
                        <Button onAction="#search" prefHeight="40.0" prefWidth="150.0" text="Search" styleClass="view-button">
                           <font><Font size="14.0" /></font>
                        </Button>
                        <Button onAction="#delete" prefHeight="40.0" prefWidth="150.0" text="Deactivate" styleClass="delete-button">
                           <font><Font size="14.0" /></font>
                        </Button>
                        <Button onAction="#reactivate" prefHeight="40.0" prefWidth="150.0" text="Reactivate" styleClass="approve-button">
                           <font><Font size="14.0" /></font>
                        </Button>
                        <Button onAction="#logout" prefHeight="40.0" prefWidth="150.0" text="Back" styleClass="nav-button">
                           <font><Font size="14.0" /></font>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="tblClients" prefHeight="300.0">
               <columns>
                  <TableColumn fx:id="colClientId" prefWidth="100.0" text="Client ID" />
                  <TableColumn fx:id="colClientName" prefWidth="200.0" text="Name" />
                  <TableColumn fx:id="colContact" prefWidth="150.0" text="Contact" />
                  <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
