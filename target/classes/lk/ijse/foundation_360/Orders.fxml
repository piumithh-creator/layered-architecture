<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.foundation_360.controller.OrderController" 
            AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" 
            AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
    
    <children>
        <VBox spacing="16.0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" 
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <children>
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Orders" textFill="#e5e7eb">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Manage customer orders and quotations" textFill="#9ca3af">
                                    <font>
                                        <Font size="12.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <Button text="New Order" onAction="#addOrder" styleClass="add-button" />
                        <Button text="Refresh" onAction="#refreshData" styleClass="view-button" />
                    </children>
                    <padding>
                        <Insets top="16" right="16" bottom="8" left="16" />
                    </padding>
                </HBox>

                <!-- Filter Section -->
                <HBox spacing="12.0">
                    <children>
                        <Label text="Filter by Status:" textFill="#9ca3af" />
                        <ComboBox fx:id="cmbStatus" prefWidth="150.0" promptText="All Statuses" />
                        <Button text="Clear Filter" onAction="#clearFilter" styleClass="secondary-button" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Search:" textFill="#9ca3af" />
                        <TextField fx:id="txtSearch" promptText="Search orders..." prefWidth="200.0" />
                    </children>
                    <padding>
                        <Insets top="0" right="16" bottom="8" left="16" />
                    </padding>
                </HBox>

                <!-- Orders Table -->
                <TableView fx:id="tblOrders" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colOrderId" text="Order ID" prefWidth="80" />
                        <TableColumn fx:id="colClientId" text="Client ID" prefWidth="100" />
                        <TableColumn fx:id="colOrderDate" text="Order Date" prefWidth="120" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="120" />
                    </columns>
                </TableView>

                <!-- Summary Bar -->
                <HBox spacing="24.0">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Total Orders" textFill="#9ca3af" styleClass="summary-label" />
                                <Label fx:id="lblTotalOrders" text="0" textFill="#e5e7eb" >
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Pending" textFill="#9ca3af" styleClass="summary-label" />
                                <Label fx:id="lblPendingOrders" text="0" textFill="#e5e7eb" >
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Approved" textFill="#9ca3af" styleClass="summary-label" />
                                <Label fx:id="lblApprovedOrders" text="0" textFill="#e5e7eb" >
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Rejected" textFill="#9ca3af" styleClass="summary-label" />
                                <Label fx:id="lblRejectedOrders" text="0" textFill="#e5e7eb" >
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets top="8" right="16" bottom="16" left="16" />
                    </padding>
                    <styleClass>
                        card
                    </styleClass>
                </HBox>
            </children>
            <padding>
                <Insets top="0" right="0" bottom="0" left="0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
